# ── App ──
APP_NAME=Agentic Payments Orchestrator
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key

# ── Neon Database ──
# Async driver (FastAPI) — note: asyncpg uses ssl=require, not sslmode
DATABASE_URL=postgresql+asyncpg://user:password@ep-example-123456.us-east-2.aws.neon.tech/dbname?ssl=require
# Sync driver (Celery workers)
SYNC_DATABASE_URL=postgresql+psycopg2://user:password@ep-example-123456.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT ──
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Stripe (test mode) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Gemini ──
GEMINI_API_KEY=your-gemini-api-key

# ── Payment provider: "stripe" or "mock" ──
PAYMENT_PROVIDER=mock
